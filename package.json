{
  "name": "rocky-pet",
  "displayName": "Rocky — Desktop Pet",
  "description": "Rocky from Project Hail Mary lives in your VS Code panel. He climbs the walls and ceiling, naps, gets excited, and shouts Rocky-isms while you code.",
  "version": "0.0.1",
  "publisher": "chiradeep-varma",
  "license": "MIT",
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Other", "Visualization"],
  "keywords": ["pet", "rocky", "project hail mary", "fun", "companion"],
  "repository": {
    "type": "git",
    "url": "https://github.com/chiradeep-varma/rocky-pet.git"
  },
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "views": {
      "panel": [
        {
          "type": "webview",
          "id": "rocky.view",
          "name": "Rocky"
        }
      ]
    },
    "commands": [
      { "command": "rocky.show", "title": "Rocky: Show Pet" },
      { "command": "rocky.hide", "title": "Rocky: Hide Pet" }
    ]
  },
  "scripts": {
    "compile": "webpack --mode development",
    "watch": "webpack --mode development --watch",
    "vscode:prepublish": "webpack --mode production",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0",
    "ts-loader": "^9.5.0",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.0",
    "@vscode/vsce": "^3.0.0"
  }
}
